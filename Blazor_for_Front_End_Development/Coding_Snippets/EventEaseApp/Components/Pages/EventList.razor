@page "/events"
@rendermode InteractiveServer
@using EventEaseApp.Models
@using EventEaseApp.Components

<PageTitle>Event List</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2>Upcoming Events</h2>
    <a href="/events/register" class="btn btn-primary">Create New Event</a>
</div>

<div class="row">
    @if (EventModel.Events != null && EventModel.Events.Count > 0)
    {
        @foreach (var evt in EventModel.Events)
        {
            <div class="col-md-6 mb-4">
                <EventCard EventDetails="evt" />
                <div class="d-flex gap-2 mt-2">
                    <a href="/events/@evt.Id" class="btn btn-outline-primary w-100">View Details</a>
                </div>
            </div>
        }
    }
    else
    {
        <p>No events found.</p>
    }
</div>

